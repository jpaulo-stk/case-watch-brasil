# Banco de dados (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=case_watch

# SSL do banco — "true" para Postgres gerenciado na nuvem (Neon/Supabase/RDS),
# necessário no deploy da Lambda. Deixe em branco/false para o Postgres local.
DB_SSL=false

# Segredo para assinar o JWT (use uma string longa e aleatória)
JWT_SECRET=

# Opcional — porta da API (padrão 3000)
# PORT=3000
