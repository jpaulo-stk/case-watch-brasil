{
  "name": "back-end",
  "packageManager": "yarn@4.6.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "typeorm": "tsx ./node_modules/typeorm/cli.js",
    "migration:generate": "yarn typeorm migration:generate -d ./src/config/data-source.ts ./src/migrations/InitSchema",
    "migration:run": "yarn typeorm migration:run -d ./src/config/data-source.ts",
    "migration:revert": "yarn typeorm migration:revert -d ./src/config/data-source.ts",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "dev:otel": "tsx watch src/otel-server.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^30.4.2",
    "serverless": "3",
    "serverless-dotenv-plugin": "^6.0.0",
    "serverless-esbuild": "^1.57.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.20.0",
    "typescript": "5"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "serverless-http": "^4.0.0",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^1.0.0",
    "zod": "^3"
  }
}
